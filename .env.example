# ----------------------------------------------------------------------
# Variables de entorno · Pulso Medellín
# Copiar este archivo a `.env` y ajustar contraseñas antes de levantar:
#     cp .env.example .env
# El archivo .env REAL está en .gitignore — nunca lo suban al repo.
# ----------------------------------------------------------------------

# --------- MinIO (S3 local) ---------
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=admin12345
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --------- AWS / región (usado por el REST Catalog y Spark) ---------
AWS_REGION=us-east-1

# --------- Iceberg REST Catalog ---------
ICEBERG_REST_PORT=8181
ICEBERG_NAMESPACE=pulsomed

# --------- Spark + Jupyter ---------
SPARK_UI_PORT=8080
JUPYTER_PORT=8888
SPARK_THRIFT_PORT=10000

# --------- MongoDB ---------
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin12345
MONGO_PORT=27017
MONGO_DATABASE=pulsomed

# --------- Compose (auxiliar) ---------
COMPOSE_PROJECT_NAME=pulsomed

# ====================================================================
# [SPRINT 2+]  Streaming
# ====================================================================
# KAFKA_BOOTSTRAP_SERVERS=kafka:9092
# KAFKA_BOOTSTRAP_SERVERS_HOST=localhost:29092
# FLINK_UI_PORT=8081
# FLINK_PARALLELISM=2

# ====================================================================
# [SPRINT 5]  Trino (bonus)
# ====================================================================
# TRINO_PORT=8084

# ====================================================================
# [SPRINT 5]  Pseudonimización HMAC
# ====================================================================
# Clave de reversión para HMAC-SHA256 sobre id_usuario de EnCicla.
# **NO** debe estar accesible desde notebooks de análisis en producción.
# En dev pueden usar cualquier string fuerte, pero rotenla antes de la entrega.
# HMAC_USER_PSEUDO_SECRET=cambiame-en-produccion-cualquier-string-largo-y-aleatorio
